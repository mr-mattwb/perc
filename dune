
(library
    (name cfg)
    (wrapped false)
    (modules tools lex propBase propParse iniParse propLex iniLex ser fileOps envParam env log dayTime time date dateTime soxi pLog)
    (libraries unix pcre)
    (flags -keep-locs -I +unix -I +str -I +../pcre)
)
(ocamlyacc (modules iniParse propParse))
(ocamllex (modules iniLex propLex lex))

(executable 
  (name cfg)
  (modules cfg)
  (libraries unix pcre str cfg)
  (flags -keep-locs)
)
